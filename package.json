{
  "name": "tf2-calculator-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:desktop": "npm -w @tf2calc/desktop run build",
    "build:react-ui": "npm -w @tf2calc/react-ui run build",
    "cli": "npm -w @tf2calc/cli run cli --",
    "desktop:dev": "npm -w @tf2calc/desktop run dev",
    "desktop:package": "npm -w @tf2calc/desktop run package",
    "lint": "eslint .",
    "preview:desktop": "npm -w @tf2calc/desktop run preview",
    "release:core": "npm -w @tf2calc/core publish --access public",
    "release:cli": "npm -w @tf2calc/cli publish --access public",
    "release:react-ui": "npm -w @tf2calc/react-ui publish --access public",
    "release": "npm run release:core && npm run release:cli && npm run release:react-ui"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0"
  }
}
