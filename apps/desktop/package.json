{
  "name": "@tf2calc/desktop",
  "version": "0.1.0",
  "description": "Desktop TF2 metal calculator built with Electron and React",
  "author": "8aratta",
  "private": true,
  "type": "module",
  "main": "./electron/main.cjs",
  "scripts": {
    "renderer:dev": "vite",
    "electron:dev": "wait-on http://localhost:5173 && electron .",
    "dev": "concurrently -k \"npm:renderer:dev\" \"npm:electron:dev\"",
    "build": "vite build",
    "package": "npm run build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tf2calc/react-ui": "0.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "41.1.1",
    "electron-builder": "^26.0.12",
    "vite": "^8.0.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.tf2.calculator",
    "productName": "TF2 Calculator",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "buildResources": "build"
    },
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    }
  }
}
